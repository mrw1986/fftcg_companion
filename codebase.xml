<file path="tool/generate_assets.dart">
 1: // tool/generate_assets.dart
 2: import 'dart:io';
 3: import 'package:image/image.dart' as img;
 4: 
 5: void main() async {
 6:   const String sourceIconPath = 'logo.png';
 7: 
 8:   try {
 9:     await generateAppAssets(sourceIconPath);
10:   } catch (e) {
11:     stderr.writeln('Error: $e');
12:     exit(1);
13:   }
14: }
15: 
16: Future<void> generateAppAssets(String sourceIconPath) async {
17:   // Load the source image
18:   final sourceFile = File(sourceIconPath);
19:   if (!await sourceFile.exists()) {
20:     stderr.writeln('Error: $sourceIconPath not found');
21:     exit(1);
22:   }
23: 
24:   var sourceImage = img.decodeImage(await sourceFile.readAsBytes());
25:   if (sourceImage == null) {
26:     stderr.writeln('Error: Could not decode image');
27:     exit(1);
28:   }
29: 
30:   // Verify and resize to 1024x1024 if needed
31:   if (sourceImage.width != 1024 || sourceImage.height != 1024) {
32:     stderr.writeln('Resizing image to 1024x1024...');
33:     sourceImage = img.copyResize(sourceImage,
34:         width: 1024, height: 1024, interpolation: img.Interpolation.linear);
35:   }
36: 
37:   // Create assets directory
38:   final assetsDir = Directory('assets/images');
39:   if (!await assetsDir.exists()) {
40:     await assetsDir.create(recursive: true);
41:   }
42: 
43:   // Generate all required assets
44:   final assets = {
45:     'splash_logo.png': 192,
46:     'splash_logo_dark.png': 192,
47:     'splash_logo_android12.png': 192,
48:     'splash_logo_android12_dark.png': 192,
49:     'app_icon.png': 1024,
50:     'app_icon_foreground.png': 1024,
51:   };
52: 
53:   for (final entry in assets.entries) {
54:     stderr.writeln('Generating ${entry.key}...');
55: 
56:     final resized = img.copyResize(sourceImage,
57:         width: entry.value,
58:         height: entry.value,
59:         interpolation: img.Interpolation.linear);
60: 
61:     final outputFile = File('${assetsDir.path}/${entry.key}');
62:     await outputFile.writeAsBytes(img.encodePng(resized));
63:     stderr.writeln('Created ${entry.key}');
64:   }
65: 
66:   stderr.writeln('\nAll assets generated successfully in assets/images/');
67:   stderr.writeln('\nNext steps:');
68:   stderr.writeln('1. Run: flutter pub run flutter_native_splash:create');
69:   stderr.writeln('2. Run: flutter pub run flutter_launcher_icons');
70: }
