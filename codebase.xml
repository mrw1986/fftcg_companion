 42:               '161248420888-o7tbfuahgloes35huibpcbceb9m3pgc7.apps.googleusercontent.com'),
 43:     ]);
 44: 
 45:     // Initialize Analytics
 46:     analytics = FirebaseAnalytics.instance;
 47:     await analytics.setAnalyticsCollectionEnabled(!kDebugMode);
 48: 
 49:     // Initialize Crashlytics
 50:     if (!kDebugMode) {
 51:       await FirebaseCrashlytics.instance.setCrashlyticsCollectionEnabled(true);
 52:       FlutterError.onError = FirebaseCrashlytics.instance.recordFlutterError;
 53:       PlatformDispatcher.instance.onError = (error, stack) {
