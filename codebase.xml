101:     return PriceHistory(
102:       cardId: cardId ?? data['cardId'] as String,
103:       points: pointsList,
104:       startDate: (data['startDate'] as Timestamp).toDate(),
105:       endDate: (data['endDate'] as Timestamp).toDate(),
106:     );
107:   }
108: 
109:   Map<String, dynamic> toFirestore() {
110:     return {
111:       'cardId': cardId,
112:       'points': points.map((point) => point.toFirestore()).toList(),
113:       'startDate': Timestamp.fromDate(startDate),
114:       'endDate': Timestamp.fromDate(endDate),
115:     };
116:   }
117: }
118: 
119: class PricePoint {
120:   final DateTime date;
121:   final double normalPrice;
122:   final double? foilPrice;
123: 
124:   const PricePoint({
125:     required this.date,
126:     required this.normalPrice,
127:     this.foilPrice,
128:   });
129: 
130:   factory PricePoint.fromFirestore(Map<String, dynamic> data) {
131:     return PricePoint(
132:       date: (data['date'] as Timestamp).toDate(),
133:       normalPrice: data['normalPrice'] as double,
134:       foilPrice: data['foilPrice'] as double?,
135:     );
136:   }
137: 
138:   Map<String, dynamic> toFirestore() {
139:     return {
140:       'date': Timestamp.fromDate(date),
141:       'normalPrice': normalPrice,
142:       'foilPrice': foilPrice,
143:     };
144:   }
145: }
