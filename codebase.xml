 65:             Row(
 66:               mainAxisAlignment: MainAxisAlignment.center,
 67:               children: [
 68:                 IconButton(
 69:                   icon: const Icon(Icons.remove),
 70:                   onPressed: quantity > 0
 71:                       ? () => onQuantityChanged(quantity - 1, isFoil)
 72:                       : null,
 73:                 ),
 74:                 Text(
 75:                   quantity.toString(),
 76:                   style: const TextStyle(
 77:                     fontSize: 16,
 78:                     fontWeight: FontWeight.bold,
 79:                   ),
 80:                 ),
 81:                 IconButton(
 82:                   icon: const Icon(Icons.add),
 83:                   onPressed: () => onQuantityChanged(quantity + 1, isFoil),
 84:                 ),
 85:               ],
 86:             ),
 87:           ],
 88:         ),
 89:       ),
 90:     );
 91:   }
