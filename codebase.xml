 4:     // Require App Check for all operations
 5:     function isValidAppCheck() {
 6:       return request.auth.token.app_check == true;
 7:     }
 8: 
 9:     // Cards collection - public read, admin write
10:     match /cards/{document=**} {
11:       allow read: if isValidAppCheck();
12:       allow write: if false;
13:     }
14: 
15:     // User-specific data
16:     match /users/{userId} {
17:       allow read, write: if isValidAppCheck() && 
