<file path="lib/widgets/price_history_chart.dart">
 1: // lib/widgets/price_history_chart.dart
 2: import 'package:flutter/material.dart';
 3: import 'package:fl_chart/fl_chart.dart';
 4: import '../models/models.dart';
 5: 
 6: class PriceHistoryChart extends StatelessWidget {
 7:   final String cardId;
 8:   final List<PricePoint> priceHistory;
 9:   final bool showFoil;
10: 
11:   const PriceHistoryChart({
12:     super.key,
13:     required this.cardId,
14:     required this.priceHistory,
15:     this.showFoil = true,
16:   });
17: 
18:   @override
19:   Widget build(BuildContext context) {
20:     if (priceHistory.isEmpty) {
21:       return const Center(
22:         child: Text('No price history available'),
23:       );
24:     }
25: 
26:     return LineChart(
27:       LineChartData(
28:         gridData: FlGridData(show: true),
29:         titlesData: FlTitlesData(
30:           leftTitles: AxisTitles(
31:             sideTitles: SideTitles(
32:               showTitles: true,
33:               reservedSize: 40,
34:               getTitlesWidget: (value, meta) {
35:                 return Text('\$${value.toStringAsFixed(2)}');
36:               },
37:             ),
38:           ),
39:           bottomTitles: AxisTitles(
40:             sideTitles: SideTitles(
41:               showTitles: true,
42:               reservedSize: 30,
43:               getTitlesWidget: (value, meta) {
44:                 final date = DateTime.fromMillisecondsSinceEpoch(value.toInt());
45:                 return Text(
46:                   '${date.month}/${date.day}',
47:                   style: const TextStyle(fontSize: 10),
48:                 );
49:               },
50:             ),
51:           ),
52:         ),
53:         borderData: FlBorderData(show: true),
54:         lineBarsData: [
55:           _buildLineChartBarData(false, Colors.blue),
56:           if (showFoil) _buildLineChartBarData(true, Colors.purple),
57:         ],
58:       ),
59:     );
60:   }
61: 
62:   LineChartBarData _buildLineChartBarData(bool isFoil, Color color) {
63:     return LineChartBarData(
64:       spots: priceHistory.map((point) {
65:         return FlSpot(
66:           point.date.millisecondsSinceEpoch.toDouble(),
67:           isFoil ? (point.foilPrice ?? 0) : point.normalPrice,
68:         );
69:       }).toList(),
70:       isCurved: true,
71:       color: color,
72:       barWidth: 2,
73:       dotData: FlDotData(show: false),
74:       belowBarData: BarAreaData(
75:         show: true,
76:         color: color.withAlpha(25), // Replace withOpacity with withAlpha
77:       ),
78:     );
79:   }
80: }
</file>

