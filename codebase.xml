 3: class CacheProvider with ChangeNotifier {
 4:   final Map<String, dynamic> _cachedData =
 5:       {}; // Made final as per best practices
 6: 
 7:   Map<String, dynamic> get cachedData => Map.unmodifiable(
 8:       _cachedData); // Added unmodifiable to ensure immutability
 9: 
10:   void updateCache(String key, dynamic value) {
11:     _cachedData[key] = value;
12:     notifyListeners();
13:   }
14: 
15:   void clearCache() {
16:     _cachedData.clear();
17:     notifyListeners();
18:   }
19: }
</file>

