 51:   Widget _buildQuantityControl(String label, int quantity, bool isFoil) {
 52:     return Material(
 53:       type: MaterialType.card,
 54:       elevation: 1,
 55:       child: Padding(
 56:         padding: const EdgeInsets.all(8.0),
