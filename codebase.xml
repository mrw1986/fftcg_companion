  4: class Deck {
  5:   final String id;
  6:   final String name;
  7:   final String description;
  8:   final String format;
  9:   final Map<String, int> cards;
 10:   final DateTime created;
 11:   final DateTime lastModified;
 12:   final bool isPublic;
 13:   final List<String> tags;
 14:   final DeckValidation validation;
 15: 
 16:   const Deck({
 17:     required this.id,
 18:     required this.name,
 19:     required this.description,
 20:     required this.format,
 21:     required this.cards,
 22:     required this.created,
 23:     required this.lastModified,
 24:     this.isPublic = false,
 25:     this.tags = const [],
 26:     required this.validation,
 27:   });
 28: 
 29:   bool get isValid => validation.isValid;
 30:   int get totalCards => cards.values
 31:       .fold(0, (accumulator, currentValue) => accumulator + currentValue);
 32: 
 33:   factory Deck.fromFirestore(Map<String, dynamic> data, {String? id}) {
 34:     return Deck(
 35:       id: id ?? data['id'] as String,
 36:       name: data['name'] as String,
 37:       description: data['description'] as String,
 38:       format: data['format'] as String,
 39:       cards: Map<String, int>.from(data['cards'] as Map),
 40:       created: (data['created'] as Timestamp).toDate(),
 41:       lastModified: (data['lastModified'] as Timestamp).toDate(),
 42:       isPublic: data['isPublic'] as bool? ?? false,
 43:       tags: List<String>.from(data['tags'] as List? ?? []),
 44:       validation: DeckValidation.fromFirestore(
 45:         data['validation'] as Map<String, dynamic>,
 46:       ),
 47:     );
 48:   }
 49: 
 50:   Map<String, dynamic> toFirestore() {
 51:     return {
 52:       'id': id,
 53:       'name': name,
 54:       'description': description,
 55:       'format': format,
 56:       'cards': cards,
 57:       'created': Timestamp.fromDate(created),
 58:       'lastModified': Timestamp.fromDate(lastModified),
 59:       'isPublic': isPublic,
 60:       'tags': tags,
 61:       'validation': validation.toFirestore(),
 62:     };
 63:   }
 64: 
 65:   Deck copyWith({
 66:     String? id,
 67:     String? name,
 68:     String? description,
 69:     String? format,
 70:     Map<String, int>? cards,
 71:     DateTime? created,
 72:     DateTime? lastModified,
 73:     bool? isPublic,
 74:     List<String>? tags,
 75:     DeckValidation? validation,
 76:   }) {
 77:     return Deck(
 78:       id: id ?? this.id,
 79:       name: name ?? this.name,
 80:       description: description ?? this.description,
 81:       format: format ?? this.format,
 82:       cards: cards ?? this.cards,
 83:       created: created ?? this.created,
 84:       lastModified: lastModified ?? this.lastModified,
 85:       isPublic: isPublic ?? this.isPublic,
 86:       tags: tags ?? this.tags,
 87:       validation: validation ?? this.validation,
 88:     );
 89:   }
 90: }
 91: 
 92: class DeckValidation {
 93:   final int totalCards;
 94:   final int backups;
 95:   final int forwards;
 96:   final int summons;
 97:   final int monsters;
 98:   final Map<String, int> elements;
 99: 
100:   const DeckValidation({
101:     required this.totalCards,
102:     required this.backups,
103:     required this.forwards,
104:     required this.summons,
105:     required this.monsters,
106:     required this.elements,
107:   });
108: 
109:   bool get isValid =>
110:       totalCards == 50 &&
111:       backups <= 3 &&
112:       forwards <= 3 &&
113:       summons <= 3 &&
114:       monsters <= 3;
115: 
116:   factory DeckValidation.fromFirestore(Map<String, dynamic> data) {
117:     return DeckValidation(
118:       totalCards: data['totalCards'] as int,
119:       backups: data['backups'] as int,
120:       forwards: data['forwards'] as int,
121:       summons: data['summons'] as int,
122:       monsters: data['monsters'] as int,
123:       elements: Map<String, int>.from(data['elements'] as Map),
124:     );
125:   }
126: 
127:   Map<String, dynamic> toFirestore() {
128:     return {
129:       'totalCards': totalCards,
130:       'backups': backups,
131:       'forwards': forwards,
132:       'summons': summons,
133:       'monsters': monsters,
134:       'elements': elements,
135:     };
136:   }
137: }
