rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Cards collection - allow public read
    match /cards/{cardId} {
      allow read: true;
      allow write: false;
    }

    // User-specific data
    match /users/{userId}/{document=**} {
      allow read, write: request.auth != null && request.auth.uid == userId;
    }
  }
}