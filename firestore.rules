rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Require App Check for all operations
    function isValidAppCheck() {
      return request.auth.token.app_check == true;
    }

    // Cards collection - public read, admin write
    match /cards/{document=**} {
      allow read: if isValidAppCheck();
      allow write: if false;
    }

    // User-specific data
    match /users/{userId} {
      allow read, write: if isValidAppCheck() && 
                           request.auth != null && 
                           request.auth.uid == userId;
    }
  }
}